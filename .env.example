# Database (SQLite local — fichier prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Auth (min 32 characters each — use different secrets)
JWT_SECRET="change-me-jwt-secret-min-32-chars-long!!"
BARCODE_HMAC_SECRET="change-me-hmac-secret-min-32-chars-long!"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="VerifyMyTicket <contact@verifymyticket.fr>"

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Upstash Redis (optional in dev — in-memory fallback)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Ticketmaster Discovery API (gratuit)
# https://developer.ticketmaster.com/ — sans clé = mode démo
TICKETMASTER_API_KEY=""

# Database (SQLite local — fichier prisma/dev.db)
# Prod Postgres : postgresql://user:pass@host:5432/db?sslmode=require
# (changer aussi provider dans prisma/schema.prisma — voir docs/DEPLOY.md)
DATABASE_URL="file:./dev.db"

# Auth (min 32 characters each — use different secrets)
JWT_SECRET="change-me-jwt-secret-min-32-chars-long!!"
BARCODE_HMAC_SECRET="change-me-hmac-secret-min-32-chars-long!"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="VerifyMyTicket <contact@verifymyticket.fr>"

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Upstash Redis (requis en prod multi-instances)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Ticketmaster Discovery API
TICKETMASTER_API_KEY=""

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Web Push (optionnel) — générer avec: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@verifymyticket.fr"

# Identité légale LCEN (obligatoire avant prod publique)
LEGAL_EDITOR_NAME=""
LEGAL_EDITOR_STATUS="Personne physique"
LEGAL_EDITOR_ADDRESS=""
LEGAL_EDITOR_POSTAL=""
LEGAL_EDITOR_CITY=""
LEGAL_EDITOR_COUNTRY="France"
LEGAL_EDITOR_EMAIL="contact@verifymyticket.fr"
LEGAL_EDITOR_PHONE=""
LEGAL_EDITOR_SIRET=""
LEGAL_EDITOR_RCS=""
LEGAL_EDITOR_CAPITAL=""
LEGAL_EDITOR_TVA=""
LEGAL_PUBLICATION_DIRECTOR=""
LEGAL_DPO_EMAIL="contact@verifymyticket.fr"
LEGAL_CONTACT_EMAIL="contact@verifymyticket.fr"
LEGAL_HOST_NAME="Vercel Inc."
LEGAL_HOST_ADDRESS="440 N Barranca Ave #4133, Covina, CA 91723, États-Unis"
LEGAL_HOST_WEBSITE="https://vercel.com"
LEGAL_LAST_UPDATE="17 juillet 2026"

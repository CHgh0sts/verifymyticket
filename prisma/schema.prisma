generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TicketCategory {
  CONCERT
  FESTIVAL
  SPORT
  THEATER
  CINEMA
  TRAIN
  FLIGHT
  OLYMPICS
  OTHER
}

enum BarcodeType {
  QR
  DATAMATRIX
  BARCODE
}

model User {
  id                     String         @id @default(cuid())
  username               String         @unique
  email                  String         @unique
  password               String
  emailVerified          DateTime?
  emailVerifyToken       String?        @unique
  emailVerifyExpires     DateTime?
  resetPasswordToken     String?        @unique
  resetPasswordExpires   DateTime?
  pendingEmail           String?
  emailChangeToken       String?        @unique
  emailChangeExpires     DateTime?
  pendingPasswordHash    String?
  passwordChangeToken    String?        @unique
  passwordChangeExpires  DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  tickets                Ticket[]
  loginAttempts          LoginAttempt[]
  auditLogs              AuditLog[]
}

model Ticket {
  id                String         @id @default(cuid())
  category          TicketCategory @default(CONCERT)
  eventName         String
  venue             String?
  city              String?
  eventDate         DateTime?
  organizer         String?
  platform          String
  orderNumber       String?
  seat              String?
  row               String?
  block             String?
  seatKeyHash       String?
  ticketCategory    String?
  purchaserName     String?
  purchaserNameHash String?
  purchasePrice     Decimal?
  purchaseDate      DateTime?
  barcodeHash       String
  barcodeSuffixHash String
  barcodeLastDigits String
  barcodeType       BarcodeType
  externalEventId   String?
  detectedDuplicate Boolean        @default(false)
  duplicateCount    Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  ownerId           String
  owner             User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([barcodeHash, ownerId])
  @@index([barcodeHash])
  @@index([barcodeSuffixHash])
  @@index([purchaserNameHash])
  @@index([seatKeyHash])
  @@index([externalEventId])
  @@index([eventName, venue, eventDate])
  @@index([ownerId])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  success   Boolean
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  meta      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
}

model CheckLog {
  id          String   @id @default(cuid())
  barcodeHash String
  found       Boolean
  ip          String?
  createdAt   DateTime @default(now())

  @@index([ip, createdAt])
  @@index([createdAt])
}

/// Vérifications publiques liées à un événement (hashes uniquement).
model CodeSighting {
  id                String    @id @default(cuid())
  /// name | seat | barcode | last4 (legacy barcode modes: full/last4 aussi acceptés)
  mode              String
  barcodeHash       String?
  barcodeSuffixHash String?
  purchaserNameHash String?
  seatKeyHash       String?
  externalEventId   String?
  eventName         String
  venue             String?
  city              String?
  eventDate         DateTime?
  checkCount        Int       @default(1)
  /// owned = déjà acheté | watching = vérif avant achat | claimed = confirmé acheté après vérif OK
  purchaseStatus    String    @default("watching")
  ip                String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  watches           CheckWatch[]

  @@index([barcodeHash])
  @@index([barcodeSuffixHash])
  @@index([purchaserNameHash])
  @@index([seatKeyHash])
  @@index([purchaseStatus])
  @@index([externalEventId])
  @@index([eventName, venue, eventDate])
  @@index([createdAt])
}

/// Emails à prévenir si la même vérif reçoit une activité ultérieure.
model CheckWatch {
  id         String       @id @default(cuid())
  email      String
  userId     String?
  sightingId String
  sighting   CodeSighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([sightingId, email])
  @@index([email])
  @@index([userId])
}
